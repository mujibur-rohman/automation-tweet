# --- Database ---
DATABASE_URL=postgres://user:pass@localhost:5432/automation

# --- RapidAPI (Threads) ---
RAPIDAPI_KEY=
RAPIDAPI_THREADS_HOST=threads-api4.p.rapidapi.com

# --- Telegram (bot per-service) ---
TELEGRAM_BOT_TOKEN=
