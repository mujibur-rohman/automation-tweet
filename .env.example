# --- Buffer (GraphQL API: https://api.buffer.com, header Authorization: Bearer) ---
BUFFER_ACCESS_TOKEN=
BUFFER_ORG_ID=
BUFFER_PROFILE_IDS=
BUFFER_POST_MODE=addToQueue

# --- Schedule (cron) — hanya sync status posted ---
SYNC_CRON=*/15 * * * *
